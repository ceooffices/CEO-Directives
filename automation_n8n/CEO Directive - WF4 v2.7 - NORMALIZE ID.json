        "jsCode": "const item = $input.first().json;\nconst formData = item.formData;\nconst task = item.task;\n\nif (!task.properties) {\n  throw new Error('Task not found or invalid');\n}\n\nconst existing = task.properties['Ghi chú & Trở ngại']?.rich_text?.[0]?.plain_text || '';\nconst ts = new Date(formData.timestamp).toLocaleString('vi-VN');\nconst newNote = `[${ts}] ${formData.notes}`;\nconst final = existing ? existing + '\\n\\n' + newNote : newNote;\n\nreturn {\n  taskId: formData.taskId,\n  email: formData.email,\n  formResponseId: formData.formResponseId,\n  taskTitle: task.properties?.['Tiêu đề']?.title?.[0]?.plain_text || 'Task',\n  taskUrl: task.url,\n  notionStatus: formData.notionStatus,\n  notes: formData.notes,\n  updateBody: JSON.stringify({\n    properties: {\n      'Tình trạng': { select: { name: formData.notionStatus } },\n      'Ghi chú & Trở ngại': { rich_text: [{ text: { content: final.substring(0, 2000) } }] }\n    }\n  })\n};"
