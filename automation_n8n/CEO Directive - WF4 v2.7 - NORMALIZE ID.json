        "jsCode": "const p = $input.first().json;\nconst row = p.body?.data || p.data || p.body || p;  // ← SỬA DÒNG NÀY!\n\nlet taskId = '', notes = '', status = '';\n\nfor (const [k, v] of Object.entries(row)) {\n  const key = k.toLowerCase();\n  if (key.includes('task') && key.includes('id')) taskId = v;\n  else if (key.includes('ghi chú')) notes = v;\n  else if (key.includes('trạng thái')) status = v;\n}\n\nlet notionStatus = 'Đúng kế hoạch';\nif (status.toLowerCase().includes('hoàn thành')) notionStatus = 'Hoàn thành';\n\nreturn {\n  taskId: (taskId || '').trim().replace(/-/g, ''),\n  email: p.respondentEmail || p.body?.respondentEmail || 'hoangkha@esuhai.com',\n  formResponseId: p.formResponseId || p.body?.formResponseId,\n  timestamp: p.timestamp || p.body?.timestamp || new Date().toISOString(),\n  notes: (notes || '').trim(),\n  notionStatus,\n  hasTaskId: taskId && taskId.length > 0\n};\n"
