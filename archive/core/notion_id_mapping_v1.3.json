  "wf1_v13_2step": {
    "version": "13.0",
    "updated": "2026-01-03",
    "description": "2-STEP APPROVAL WORKFLOW",
    "step1": {
      "name": "Người chỉ đạo duyệt",
      "query": {
        "filter": "Status = 'Chờ làm rõ' AND '✅ Đã duyệt bởi người chỉ đạo' is_empty"
      },
      "email_to": "Email người chỉ đạo (rollup)",
      "cc": ["hoangkha@esuhai.com"],
      "subject": "[Cần Duyệt] [title]",
      "update": "Status = 'Đã gửi email'"
    },
    "step2": {
      "name": "Đầu mối nhận việc",
      "query": {
        "filter": "'✅ Đã duyệt' = 'Đã duyệt' AND Status ≠ 'Đã tạo task' AND (LENH_GUI_LOI_NHAC is_empty OR 'Gửi lời nhắc')"
      },
      "email_to": "Email đầu mối (rollup)",
      "cc": ["Email người chỉ đạo", "hoangkha@esuhai.com", "vynnl@esuhai.com"],
      "subject": "[Cần Làm Rõ] [title] - Hạn: [T4]",
      "update": "LENH_GUI_LOI_NHAC = 'Đã nhắc', Status = 'Đã gửi email'"
    },
    "validation": {
      "if_node": "sendTo && emailSubject must not be empty",
      "on_fail": "Log to WF Logs with Status = ⚠️ Warning",
      "error_details": "Missing: To/Subject"
    }
  },

