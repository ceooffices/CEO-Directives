# =============================================
# CEO Directive Automation — Environment Config
# Copy file này thành .env rồi điền giá trị thực
# =============================================

# --- NOTION ---
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Database IDs (lấy từ URL Notion)
NOTION_MEETINGS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_OUTCOMES_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CLARIFICATIONS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_HR_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PROJECTS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_REPORTS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- EMAIL (Gmail App Password) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=CEO Notification <your-email@gmail.com>

# --- GOOGLE FORM RESPONSES (WF4/WF5) ---
GOOGLE_FORM_ESCALATION_RESPONSES=https://docs.google.com/spreadsheets/d/xxxxx/gviz/tq?tqx=out:json
GOOGLE_FORM_REMINDER_RESPONSES=https://docs.google.com/spreadsheets/d/xxxxx/gviz/tq?tqx=out:json
ESCALATION_FORM_URL=https://docs.google.com/forms/d/e/xxxxx/viewform
REMINDER_FORM_URL=https://docs.google.com/forms/d/e/xxxxx/viewform

# --- OPENCLAW BRIDGE ---
BRIDGE_URL=http://localhost:3100
OPENCLAW_GATEWAY_TOKEN=your-secure-token-here

# --- TELEGRAM BOT ---
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_CHAT_ID=123456789
TELEGRAM_ALLOWED_USERS=123456789

# --- AI (OpenAI) ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- DASHBOARD ---
DASHBOARD_SHEETS_URL=https://docs.google.com/spreadsheets/d/xxxxx/gviz/tq?tqx=out:json
