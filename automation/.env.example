# =============================================
# CEO Directive Automation — Environment Config
# Cập nhật: 2026-03-16
# Copy file này thành .env rồi điền giá trị thực
# =============================================

# --- NOTION (DEPRECATED — chỉ giữ cho bod-import.js legacy) ---
# NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_CLARIFICATIONS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_HR_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- TELEGRAM BOT (NemoClaw unified) ---
# ✅ Dùng chung bot NemoClaw — BỎ bot riêng CEO_DIR
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Chat ID admin nhận thông báo lỗi hệ thống (cũng dùng cho access control)
ADMIN_CHAT_ID=123456789
# Danh sách user IDs được phép dùng bot (comma-separated, bỏ trống = ai cũng dùng được)
TELEGRAM_ALLOWED_USERS=123456789

# --- SIGNAL CLI BOT ---
SIGNAL_API_URL=http://localhost:8080
SIGNAL_BOT_NUMBER=+84xxxxxxxxx
SIGNAL_ADMIN_NUMBERS=+84xxxxxxxxx
SIGNAL_BOT_NAME=Gravity
SIGNAL_ALLOWED_NUMBERS=+84xxxxxxxxx,+84xxxxxxxxx
SIGNAL_GROUP_COOLDOWN_SEC=5

# --- EMAIL (Gmail App Password) ---
EMAIL_VIA_N8N=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=Gravity Bot
SMTP_FROM_EMAIL=ceo.offices@esuhai.com
SIGNAL_DEFAULT_EMAIL=your-email@gmail.com

# --- GOOGLE FORM RESPONSES (WF4/WF5) ---
FORM_WF4_RESPONSE_SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FORM_WF5_RESPONSE_SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- GITHUB ---
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=ceooffices/esuhai-strategy-2026

# --- AI (Gemini primary, OpenAI fallback) ---
# ===== AI Provider (ưu tiên: Claude > Gemini > OpenAI) =====

# Claude (Priority 1 — khuyến nghị)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Gemini (Priority 2 — fallback)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-pro

# OpenAI (Priority 3 — fallback cuối)
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- PORTS (tránh xung đột với CEO_Office_Hub) ---
PORT_BRIDGE=3101
PORT_PANEL=9001
PORT_DASHBOARD=8081

# --- NEMOCLAW BRIDGE ---
BRIDGE_URL=http://localhost:3101
NEMOCLAW_GATEWAY_TOKEN=your-secure-token-here

# --- DASHBOARD ---
DASHBOARD_URL=https://ceodirectives.vercel.app

# --- SUPABASE (Phase 1-2) ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# --- CRON NOTIFICATIONS ---
# true = gửi tin nhắn Telegram khi cron trigger
# false = chỉ log console, không gửi (tránh spam khi CEO_Office_Hub cũng chạy)
ENABLE_CRON_NOTIFICATIONS=false

# --- DEBUG / SAFETY ---
# Khi set biến này, MỌI email sẽ được chuyển hướng về địa chỉ này thay vì gửi cho nhân viên thật
# Subject sẽ đổi thành [T-REDIRECT from <original_to>] để dễ nhận biết
# BỎ TRỐNG hoặc xóa dòng này khi chạy production thật
DEBUG_EMAIL_CATCH_ALL=hoangkha@esuhai.com

# --- LOGGING ---
LOG_LEVEL=INFO
