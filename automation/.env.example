# =============================================
# CEO Directive Automation — Environment Config
# Cập nhật: 2026-03-16
# Copy file này thành .env rồi điền giá trị thực
# =============================================

# --- NOTION ---
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Database IDs (lấy từ URL Notion)
NOTION_MEETINGS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_OUTCOMES_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CLARIFICATIONS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_HR_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PROJECTS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_REPORTS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- TELEGRAM BOT ---
# Hỗ trợ cả TELEGRAM_BOT_TOKEN hoặc BOT_TOKEN
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Chat ID admin nhận thông báo lỗi hệ thống (cũng dùng cho access control)
ADMIN_CHAT_ID=123456789
# Danh sách user IDs được phép dùng bot (comma-separated, bỏ trống = ai cũng dùng được)
TELEGRAM_ALLOWED_USERS=123456789

# --- SIGNAL CLI BOT ---
SIGNAL_API_URL=http://localhost:8080
SIGNAL_BOT_NUMBER=+84xxxxxxxxx
SIGNAL_ADMIN_NUMBERS=+84xxxxxxxxx
SIGNAL_BOT_NAME=Gravity
SIGNAL_ALLOWED_NUMBERS=+84xxxxxxxxx,+84xxxxxxxxx
SIGNAL_GROUP_COOLDOWN_SEC=5

# --- EMAIL (Gmail App Password) ---
EMAIL_VIA_N8N=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=Gravity Bot
SMTP_FROM_EMAIL=ceo.offices@esuhai.com
SIGNAL_DEFAULT_EMAIL=your-email@gmail.com

# --- GOOGLE FORM RESPONSES (WF4/WF5) ---
FORM_WF4_RESPONSE_SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FORM_WF5_RESPONSE_SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- GITHUB ---
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=ceooffices/esuhai-strategy-2026

# --- AI (Gemini primary, OpenAI fallback) ---
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-pro
# OpenAI chỉ dùng khi không có GEMINI_API_KEY
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OPENCLAW BRIDGE ---
BRIDGE_URL=http://localhost:3100
OPENCLAW_GATEWAY_TOKEN=your-secure-token-here

# --- DASHBOARD ---
DASHBOARD_URL=http://localhost:3000

# --- LOGGING ---
LOG_LEVEL=INFO
