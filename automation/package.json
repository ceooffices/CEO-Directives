{
  "name": "ceo-directive-automation",
  "version": "2.0.0",
  "description": "CEO Directive Automation Engine v2 - Full WF1-6 Pipeline",
  "main": "scheduler.js",
  "scripts": {
    "start": "node scheduler.js",
    "start:dry": "node scheduler.js --dry-run",
    "wf1": "node wf1-approval.js",
    "wf1:dry": "node wf1-approval.js --dry-run",
    "wf2": "node wf2-directive-progress.js",
    "wf2:dry": "node wf2-directive-progress.js --dry-run",
    "wf2:form": "node wf2-form-processor.js",
    "wf2:form:dry": "node wf2-form-processor.js --dry-run",
    "wf3": "node wf3-directive-status.js",
    "wf3:dry": "node wf3-directive-status.js --dry-run",
    "wf4": "node wf4-directive-escalation.js",
    "wf4:dry": "node wf4-directive-escalation.js --dry-run",
    "wf4:form": "node wf4-form-processor.js",
    "wf4:form:dry": "node wf4-form-processor.js --dry-run",
    "wf5": "node wf5-reminders.js",
    "wf5:dry": "node wf5-reminders.js --dry-run",
    "wf5:form": "node wf5-form-processor.js",
    "wf5:form:dry": "node wf5-form-processor.js --dry-run",
    "wf6": "node wf6-dashboard-sync.js",
    "wf6:dry": "node wf6-dashboard-sync.js --dry-run",
    "hm50": "node hm50-linker.js",
    "hm50:dry": "node hm50-linker.js --dry-run",
    "run:all": "node scheduler.js --run-now all",
    "run:all:dry": "node scheduler.js --run-now all --dry-run",
    "import:kpi": "node import-commitments.js",
    "import:kpi:dry": "node import-commitments.js --dry-run",
    "test:email": "node lib/email-sender.js --test",
    "bridge": "node openclaw-bridge.js",
    "bridge:test": "node -e \"const http=require('http');http.get('http://localhost:3100/health',r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>console.log(d))})\"",
    "bot": "node telegram-bot.js",
    "bot:test": "node telegram-bot.js --test",
    "ai:patterns": "node ai-analyzer.js patterns",
    "ai:risks": "node ai-analyzer.js risks",
    "report:weekly": "node report-generator.js weekly",
    "report:weekly:send": "node report-generator.js weekly --send",
    "report:monthly": "node report-generator.js monthly"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.0",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^6.9.0",
    "openai": "^6.29.0"
  }
}
